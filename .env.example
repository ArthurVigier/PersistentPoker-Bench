# PersistentPoker-Bench environment template.
# Copy this file to `.env` for local runs. Never commit `.env`.

# Provider API keys used by LiteLLM-backed tournament configs.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=

# Optional LiteLLM wire/request debugging. Very verbose; keep false for normal runs.
LITELLM_DEBUG=false

# Optional lowercase aliases supported by the CLI loader.
openai_api_key=
claude_api_key=
anthropic_api_key=
gemini_api_key=
google_api_key=
mistral_api_key=
xai_api_key=
deepseek_api_key=

# Optional smoke-test controls.
PPB_ENABLE_EXTERNAL_SMOKE=false
OPENAI_SMOKE_MODEL=
OPENAI_SMOKE_SEED=20260428
OPENAI_SMOKE_MAX_TOKENS=180
OPENAI_SMOKE_TIMEOUT_SECONDS=45
XAI_SMOKE_MODEL=
XAI_SMOKE_SEED=20260428
XAI_SMOKE_MAX_TOKENS=180
XAI_SMOKE_TIMEOUT_SECONDS=60

# Optional Hugging Face publishing helpers.
HF_TOKEN=
